\@writefile{toc}{\contentsline {paragraph}{E1 --- Decision-tree refinement funnel (UCI Adult, $n=45{,}222$).}{17}{section*.30}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces E1: tree-depth funnel on UCI Adult ($n = 45{,}222$, subset of depths $\{1, 5, 10, 15\}$ shown; full table $d = 1, \ldots  , 15$ in \texttt  {experiments/results/e1.json}). CART's train error matches $\varepsilon ^{*}_{\Pi _d}$ to four decimal places at every depth: leaves vote majority, so CART literally implements the plug-in achiever of \cref  {thm:sandwich}, and the bracket is therefore an \emph  {a-priori} statement about a classifier that is later trained. Bracket width drops from $0.159$ at $d=1$ to $0.104$ at $d=15$, while staying everywhere below the universal $w^{*}$ of \cref  {cor:slack}, and $\varepsilon ^{*}$ shrinks monotonically as required by \cref  {prop:refine}. The empirical bracket on $V$ (Adult, $n = 45{,}222$) concentrates on its population analogue $\varepsilon ^{*}_{\Pi ,\mu }$ at the $\mathcal  O(1/\sqrt  n)$ rate of \cref  {prop:pop} (\cref  {rem:emp-pop}); the empirical reading above is therefore the practitioner-facing one and the population reading inherits the E7 $(\delta _{\min },\eta _{\min })$ caveat. Figure: \texttt  {experiments/figures/e1\_refinement\_funnel.pdf}.}}{17}{table.2}\protected@file@percent }
\newlabel{tab:e1}{{2}{17}{E1: tree-depth funnel on UCI Adult ($n = 45{,}222$, subset of depths $\{1, 5, 10, 15\}$ shown; full table $d = 1, \ldots , 15$ in \texttt {experiments/results/e1.json}). CART's train error matches $\eps ^{*}_{\Pi _d}$ to four decimal places at every depth: leaves vote majority, so CART literally implements the plug-in achiever of \cref {thm:sandwich}, and the bracket is therefore an \emph {a-priori} statement about a classifier that is later trained. Bracket width drops from $0.159$ at $d=1$ to $0.104$ at $d=15$, while staying everywhere below the universal $w^{*}$ of \cref {cor:slack}, and $\eps ^{*}$ shrinks monotonically as required by \cref {prop:refine}. The empirical bracket on $V$ (Adult, $n = 45{,}222$) concentrates on its population analogue $\eps ^{*}_{\Pi ,\mu }$ at the $\mathcal O(1/\sqrt n)$ rate of \cref {prop:pop} (\cref {rem:emp-pop}); the empirical reading above is therefore the practitioner-facing one and the population reading inherits the E7 $(\delta _{\min },\eta _{\min })$ caveat. Figure: \texttt {experiments/figures/e1\_refinement\_funnel.pdf}}{table.2}{}}
\newlabel{tab:e1@cref}{{[table][2][]2}{[1][17][]17}{}{}{}}
