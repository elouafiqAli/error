\citation{morris2019wl}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces E2b: marginal-aware slack (\cref  {prop:marginal}) on real binary labels. On UCI Adult ($\pi _{*} \approx 0.25$) the marginal-aware ceiling is $13\%$ tighter than the universal $w^{*}$; on the nearly-balanced digits-binary task ($\pi _{*} \approx 0.5$) the two coincide, as \cref  {prop:marginal} predicts (the marginal-aware ceiling $w^{*}(\pi _{*})$ reduces to the universal $w^{*}$ exactly when $\pi _{*}$ saturates the entropy-error tension at the worst-case prior). Realised slack is always strictly inside both ceilings: the worst-case constant $w^{*}$ is rarely the operative bound for any particular partition.}}{19}{table.4}\protected@file@percent }
\newlabel{tab:e2b}{{4}{19}{E2b: marginal-aware slack (\cref {prop:marginal}) on real binary labels. On UCI Adult ($\pi _{*} \approx 0.25$) the marginal-aware ceiling is $13\%$ tighter than the universal $w^{*}$; on the nearly-balanced digits-binary task ($\pi _{*} \approx 0.5$) the two coincide, as \cref {prop:marginal} predicts (the marginal-aware ceiling $w^{*}(\pi _{*})$ reduces to the universal $w^{*}$ exactly when $\pi _{*}$ saturates the entropy-error tension at the worst-case prior). Realised slack is always strictly inside both ceilings: the worst-case constant $w^{*}$ is rarely the operative bound for any particular partition}{table.4}{}}
\newlabel{tab:e2b@cref}{{[table][4][]4}{[1][18][]19}{}{}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces E3: empirical training-label bracket of the $1$-WL partition $\Pi _{L}$ at depth $L$ on five feature-rich citation / social graphs (CPU only, no MPNN instantiated). The added column $m_{L}/|V|$ exposes a partition-cardinality artefact discussed below: on ogbn-arxiv the depth-$3$ $1$-WL partition has $95.6\%$ singleton cells, so the bracket pinch is \emph  {partition-cardinality collapse}, not bound tightness; on Cora and Twitch-EN the same effect, less dramatic; on CiteSeer and PubMed the partition is still genuinely coarse and the bracket is a non-tautological certificate. Full funnels $L = 0, \ldots  , L_{\max }$ in \texttt  {experiments/results/e3.json}; per-dataset funnel figures in \texttt  {experiments/figures/e3\_*\_funnel.pdf}. All endpoints in this table are the empirical $\varepsilon ^{*}_{\Pi _{L},\hat  \mu _{n}}$ on the labelled training set; the corresponding population reading $\varepsilon ^{*}_{\Pi _{L},\mu }$ differs from each row by $O(1/\sqrt  n)$ through \cref  {prop:pop}, with the marginal-weighted form $\varepsilon ^{*}_{\Pi _{L},\mu } = \DOTSB \sum@ \slimits@ _{C \in \Pi _{L}} \mu (C)\min (\bar  P_{C}, 1-\bar  P_{C})$ of \cref  {rem:emp-pop}.}}{19}{table.5}\protected@file@percent }
\newlabel{tab:e3}{{5}{19}{E3: empirical training-label bracket of the $1$-WL partition $\Pi _{L}$ at depth $L$ on five feature-rich citation / social graphs (CPU only, no MPNN instantiated). The added column $m_{L}/|V|$ exposes a partition-cardinality artefact discussed below: on ogbn-arxiv the depth-$3$ $1$-WL partition has $95.6\%$ singleton cells, so the bracket pinch is \emph {partition-cardinality collapse}, not bound tightness; on Cora and Twitch-EN the same effect, less dramatic; on CiteSeer and PubMed the partition is still genuinely coarse and the bracket is a non-tautological certificate. Full funnels $L = 0, \ldots , L_{\max }$ in \texttt {experiments/results/e3.json}; per-dataset funnel figures in \texttt {experiments/figures/e3\_*\_funnel.pdf}. All endpoints in this table are the empirical $\eps ^{*}_{\Pi _{L},\hat \mu _{n}}$ on the labelled training set; the corresponding population reading $\eps ^{*}_{\Pi _{L},\mu }$ differs from each row by $O(1/\sqrt n)$ through \cref {prop:pop}, with the marginal-weighted form $\eps ^{*}_{\Pi _{L},\mu } = \sum _{C \in \Pi _{L}} \mu (C)\min (\bar P_{C}, 1-\bar P_{C})$ of \cref {rem:emp-pop}}{table.5}{}}
\newlabel{tab:e3@cref}{{[table][5][]5}{[1][19][]19}{}{}{}}
