\@writefile{toc}{\contentsline {paragraph}{E6 --- Cost comparison vs one training epoch.}{28}{section*.45}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {14}{\ignorespaces E6: cost of evaluating the bracket vs one training epoch. The bracket is two orders of magnitude cheaper than a single CART fit on every dataset $\ge 500$ samples, and remains cheaper than \emph  {one} LBFGS epoch of logistic regression everywhere except UCI Adult, where it costs roughly half an LR epoch. Bracket cost scales linearly in $n$ (the dominant term is a single pass over the $n$ cell labels) and is independent of feature dimension.}}{28}{table.14}\protected@file@percent }
\newlabel{tab:e6}{{14}{28}{E6: cost of evaluating the bracket vs one training epoch. The bracket is two orders of magnitude cheaper than a single CART fit on every dataset $\ge 500$ samples, and remains cheaper than \emph {one} LBFGS epoch of logistic regression everywhere except UCI Adult, where it costs roughly half an LR epoch. Bracket cost scales linearly in $n$ (the dominant term is a single pass over the $n$ cell labels) and is independent of feature dimension}{table.14}{}}
\newlabel{tab:e6@cref}{{[table][14][]14}{[1][28][]28}{}{}{}}
\@writefile{toc}{\contentsline {paragraph}{E7 --- Real-data Proposition~\ref {prop:pop} concentration.}{28}{section*.46}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {15}{\ignorespaces E7: real-data concentration of the empirical bracket to the full-data bracket on UCI Adult. Mean deviation shrinks as $\Theta (1/\sqrt  {n})$ exactly as \cref  {prop:pop} predicts; the $p_{95}$ deviation stays comfortably inside the $\kappa $-free Hoeffding bound at every sample size. The $\kappa $-free column uses constant $1$ in place of the proved multiplier $\kappa (\delta ,\eta ) = (1/\sqrt  {\delta })(1+\log _{2}((1-\eta )/\eta ))$ of \cref  {prop:pop}; on the Adult CART partition (\texttt  {verify\_prop7\_constant.py}) the empirical $(\delta _{\min }, \eta _{\min }) = (2.59\!\times \!10^{-3},\, 2.10\!\times \!10^{-3})$ give $\kappa \approx 194$, so the proved bound is vacuous ($>1$) for every $n$ in the grid: it is the $\eta _{\min } \to 0$ degeneracy --- one near-pure CART leaf \citep  {antos2001convergence} --- not a mis-stated proof constant. The $\kappa $-free bound is the practically useful version in this regime and covers $p_{95}$ everywhere; empirical coverage is $1.000$ at every $n$ versus the nominal $0.95$ target.}}{28}{table.15}\protected@file@percent }
\newlabel{tab:e7}{{15}{28}{E7: real-data concentration of the empirical bracket to the full-data bracket on UCI Adult. Mean deviation shrinks as $\Theta (1/\sqrt {n})$ exactly as \cref {prop:pop} predicts; the $p_{95}$ deviation stays comfortably inside the $\kappa $-free Hoeffding bound at every sample size. The $\kappa $-free column uses constant $1$ in place of the proved multiplier $\kappa (\delta ,\eta ) = (1/\sqrt {\delta })(1+\log _{2}((1-\eta )/\eta ))$ of \cref {prop:pop}; on the Adult CART partition (\texttt {verify\_prop7\_constant.py}) the empirical $(\delta _{\min }, \eta _{\min }) = (2.59\!\times \!10^{-3},\, 2.10\!\times \!10^{-3})$ give $\kappa \approx 194$, so the proved bound is vacuous ($>1$) for every $n$ in the grid: it is the $\eta _{\min } \to 0$ degeneracy --- one near-pure CART leaf \citep {antos2001convergence} --- not a mis-stated proof constant. The $\kappa $-free bound is the practically useful version in this regime and covers $p_{95}$ everywhere; empirical coverage is $1.000$ at every $n$ versus the nominal $0.95$ target}{table.15}{}}
\newlabel{tab:e7@cref}{{[table][15][]15}{[1][28][]28}{}{}{}}
